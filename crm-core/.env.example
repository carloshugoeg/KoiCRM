# Database - app user (no BYPASSRLS, used at runtime)
DATABASE_URL=postgres://app_user:app_pass@localhost:5432/koicrm

# Database - admin user (BYPASSRLS, used for migrations and seeds only)
DATABASE_ADMIN_URL=postgres://admin_user:admin_pass@localhost:5432/koicrm

# Auth (Auth.js v5)
AUTH_SECRET=changeme_generate_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000
# Public app URL for join links copied in the browser (defaults to window.location.origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (optional — leave empty to hide Google buttons)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Object storage (S3-compatible, e.g. Cloudflare R2)
# Account endpoint only — do NOT append /bucket-name
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_PUBLIC_URL=   # e.g. https://pub-<hash>.r2.dev or https://cdn.yourdomain.com

# App
LOG_LEVEL=info
NODE_ENV=development

# Membership gate (renewal / acquisition contact on /app/access)
MEMBERSHIP_CONTACT_EMAIL=soporte@koisoftware.com
MEMBERSHIP_CONTACT_PHONE=
MEMBERSHIP_CONTACT_LABEL=Koi Software
