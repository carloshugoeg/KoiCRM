
// ─── Business Models (T2.2) ──────────────────────────────────────────────────

model Pipeline {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages PipelineStage[]
  deals  Deal[]

  @@index([tenantId])
}

model PipelineStage {
  id         String  @id @default(cuid())
  tenantId   String
  pipelineId String
  order      Int
  key        String
  label      String
  sublabel   String?
  color      String
  iconKey    String
  locked     Boolean @default(false)

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, key])
  @@index([tenantId])
}

model CatalogItem {
  id         String  @id @default(cuid())
  tenantId   String
  catalogKey String
  key        String
  label      String
  color      String?
  iconKey    String?
  metadata   Json?
  order      Int     @default(0)
  active     Boolean @default(true)

  @@unique([tenantId, catalogKey, key])
  @@index([tenantId, catalogKey])
}

model Client {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  company    String?
  phone      String?
  whatsapp   String?
  email      String?
  notes      String?
  customData Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deals       Deal[]
  attachments Attachment[]
  clientNotes Note[]

  @@unique([tenantId, name, company])
  @@index([tenantId])
}

model Deal {
  id             String   @id
  tenantId       String
  pipelineId     String
  stageId        String
  clientId       String?
  ownerId        String
  channelKey     String
  statusKey      String
  name           String
  company        String?
  phone          String?
  whatsapp       String?
  email          String?
  value          Decimal  @db.Decimal(14, 2)
  isArchived     Boolean  @default(false)
  customData     Json?
  createdAt      DateTime @default(now())
  stageEnteredAt DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client      Client?       @relation(fields: [clientId], references: [id])
  pipeline    Pipeline      @relation(fields: [pipelineId], references: [id])
  stage       PipelineStage @relation(fields: [stageId], references: [id])
  owner       User          @relation(fields: [ownerId], references: [id])
  equipment   DealEquipment[]
  quotes      Quote[]
  payments    Payment[]
  followUps   FollowUp[]
  notes       Note[]
  attachments Attachment[]

  @@index([tenantId, isArchived])
  @@index([tenantId, stageId])
  @@index([tenantId, ownerId])
  @@index([tenantId, clientId])
}

model DealEquipment {
  dealId       String
  equipmentKey String
  customLabel  String?

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@id([dealId, equipmentKey])
}

model Quote {
  id         String   @id @default(cuid())
  tenantId   String
  dealId     String
  number     String
  date       DateTime
  fileUrl    String?
  isVoid     Boolean  @default(false)
  customData Json?
  createdAt  DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId, dealId])
}

model Payment {
  id         String   @id @default(cuid())
  tenantId   String
  dealId     String
  number     String
  date       DateTime
  fileUrl    String?
  isVoid     Boolean  @default(false)
  customData Json?
  createdAt  DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId, dealId])
}

model Attachment {
  id        String   @id @default(cuid())
  tenantId  String
  dealId    String?
  clientId  String?
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId, dealId])
}

model FollowUp {
  id          String    @id @default(cuid())
  tenantId    String
  dealId      String
  date        DateTime
  note        String?
  result      String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId, dealId])
  @@index([tenantId, completed, date])
}

model Note {
  id          String   @id @default(cuid())
  tenantId    String
  dealId      String?
  clientId    String?
  text        String
  createdById String?
  createdAt   DateTime @default(now())

  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId, dealId])
  @@index([tenantId, clientId])
}

model Activity {
  id        String   @id @default(cuid())
  tenantId  String
  entity    String
  entityId  String
  type      String
  payload   Json
  userId    String?
  createdAt DateTime @default(now())

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
}

model SavedView {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  entity    String
  name      String
  config    Json
  createdAt DateTime @default(now())

  @@index([tenantId, entity])
}

model Counter {
  tenantId String
  key      String
  value    Int    @default(0)

  @@id([tenantId, key])
}

model CustomFieldDefinition {
  id        String   @id @default(cuid())
  tenantId  String
  entity    String
  key       String
  label     String
  type      String
  options   Json?
  required  Boolean  @default(false)
  order     Int      @default(0)
  metadata  Json?
  createdAt DateTime @default(now())

  @@unique([tenantId, entity, key])
  @@index([tenantId, entity])
}
