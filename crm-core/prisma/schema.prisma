generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_ADMIN_URL")
}

// ─── Identity & Tenancy ──────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  SUPERVISOR
  MEMBER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

model Tenant {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  name                  String
  industrySlug          String?
  /// Owner workspace license; when false, no member can access the embudo.
  subscriptionValidated Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  branding     TenantBranding?
  settings     TenantSettings?
  memberships  Membership[]
  invitations  Invitation[]
  joinLinks    JoinLink[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  password      String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  memberships      Membership[]
  ownedDeals       Deal[]       @relation("DealOwner")
  createdDeals     Deal[]       @relation("DealCreator")
  dealViews        DealViewer[]
  accounts         Account[]
  sessions         Session[]
  followUpsCreated FollowUp[]   @relation("FollowUpCreator")
  notesCreated     Note[]       @relation("NoteCreator")
  activities       Activity[]   @relation("ActivityUser")
  savedViews       SavedView[]  @relation("SavedViewUser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id            String           @id @default(cuid())
  userId        String
  tenantId      String
  role          Role
  status        MembershipStatus @default(ACTIVE)
  // HMAC(pin, AUTH_SECRET) of the member's 4-digit action PIN. Deterministic so it is
  // both indexable (resolve the author from the PIN) and unique per workspace. Null = no PIN.
  actionPinHash String?
  createdAt     DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@unique([tenantId, actionPinHash])
  @@index([tenantId])
}

model Invitation {
  id         String    @id @default(cuid())
  tenantId   String
  email      String
  role       Role      @default(MEMBER)
  token      String    @unique @default(cuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
}

/// Reusable workspace join link with configurable role (updatable without regenerating token).
model JoinLink {
  id        String    @id @default(cuid())
  tenantId  String
  token     String    @unique @default(cuid())
  role      Role      @default(MEMBER)
  label     String?
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantBranding {
  tenantId      String  @id
  logoUrl       String?
  primaryColor  String?
  bgColorLight  String?
  bgColorDark   String?
  bgImageUrl    String?
  headerBgColor String?
  kpiBgColor    String?
  productName   String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantSettings {
  tenantId            String  @id
  locale              String  @default("es-GT")
  currency            String  @default("GTQ")
  timezone            String  @default("America/Guatemala")
  phoneFormat         String  @default("XXXX-XXXX")
  whatsappCountryCode String  @default("+502")
  dealIdPrefix        String  @default("DEAL")
  dealIdYearDigits    Int     @default(2)
  defaultPipelineId   String?
  storageMaxBytes     BigInt  @default(8589934592)
  storageUsedBytes    BigInt  @default(0)
  fileSizeMaxBytes    BigInt  @default(104857600)  // 100 MiB per file
  // When true, sensitive deal writes require a 4-digit action PIN that identifies the author.
  pinEnabled             Boolean @default(false)
  // Seconds a verified PIN stays unlocked on a device before it is asked again.
  pinUnlockWindowSeconds Int     @default(300)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model IndustryTemplate {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  config    Json
  createdAt DateTime @default(now())
}

// ─── Business Models (T2.2) ──────────────────────────────────────────────────

model Pipeline {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages PipelineStage[]
  deals  Deal[]

  @@index([tenantId])
}

model PipelineStage {
  id              String  @id @default(cuid())
  tenantId        String
  pipelineId      String
  order           Int
  key             String
  label           String
  sublabel        String?
  color           String
  iconKey         String
  locked          Boolean @default(false)
  requiresQuote   Boolean @default(false)
  requiresPayment Boolean @default(false)

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, key])
  @@index([tenantId])
}

model CatalogItem {
  id         String  @id @default(cuid())
  tenantId   String
  catalogKey String
  key        String
  label      String
  color      String?
  iconKey    String?
  metadata   Json?
  order      Int     @default(0)
  active     Boolean @default(true)
  // For the "equipment" catalog this expresses a 2-level taxonomy: parentId null = categoría
  // (equipo de interés), parentId set = subcategoría of that categoría. Other catalogs stay flat.
  parentId   String?

  parent   CatalogItem?  @relation("CatalogItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children CatalogItem[] @relation("CatalogItemHierarchy")

  @@unique([tenantId, catalogKey, key])
  @@index([tenantId, catalogKey])
  @@index([parentId])
}

model Client {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  company    String?
  phone      String?
  whatsapp   String?
  email      String?
  notes      String?
  customData Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deals       Deal[]
  attachments Attachment[]
  clientNotes Note[]

  @@unique([tenantId, name, company])
  @@index([tenantId])
}

model Deal {
  id             String   @id
  tenantId       String
  pipelineId     String
  stageId        String
  clientId       String?
  ownerId        String
  createdById    String?
  channelKey     String
  statusKey      String
  name           String
  company        String?
  phone          String?
  whatsapp       String?
  email          String?
  value          Decimal  @db.Decimal(14, 2)
  isArchived     Boolean  @default(false)
  customData     Json?
  createdAt      DateTime @default(now())
  stageEnteredAt DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client      Client?       @relation(fields: [clientId], references: [id])
  pipeline    Pipeline      @relation(fields: [pipelineId], references: [id])
  stage       PipelineStage @relation(fields: [stageId], references: [id])
  owner       User          @relation("DealOwner", fields: [ownerId], references: [id])
  createdBy   User?         @relation("DealCreator", fields: [createdById], references: [id], onDelete: SetNull)
  equipment   DealEquipment[]
  quotes      Quote[]
  payments    Payment[]
  followUps   FollowUp[]
  notes       Note[]
  attachments Attachment[]
  viewers     DealViewer[]

  @@index([tenantId, isArchived])
  @@index([tenantId, stageId])
  @@index([tenantId, ownerId])
  @@index([tenantId, clientId])
  @@index([tenantId, createdById])
  @@index([tenantId, createdAt])
  @@index([tenantId, channelKey])
}

model DealEquipment {
  dealId         String
  // Denormalized parent categoría key, so cards/stats/filters read the category without a join.
  categoryKey    String
  // The selected subcategoría's CatalogItem.key (namespaced "<categoryKey>__<subKey>").
  subcategoryKey String

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@id([dealId, subcategoryKey])
  @@index([categoryKey])
}

/// Read-only access grant created when a deal is ceded: the previous owner keeps
/// visibility (but not edit) until the new owner returns the deal to them.
model DealViewer {
  id        String   @id @default(cuid())
  tenantId  String
  dealId    String
  userId    String
  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealId, userId])
  @@index([tenantId, userId])
}

model Quote {
  id         String   @id @default(cuid())
  tenantId   String
  dealId     String
  number     String
  date       DateTime
  fileUrl    String?
  isVoid     Boolean  @default(false)
  customData Json?
  createdAt  DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId, dealId])
}

model Payment {
  id         String   @id @default(cuid())
  tenantId   String
  dealId     String
  number     String
  date       DateTime
  fileUrl    String?
  isVoid     Boolean  @default(false)
  customData Json?
  createdAt  DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([tenantId, dealId])
}

model Attachment {
  id        String   @id @default(cuid())
  tenantId  String
  dealId    String?
  clientId  String?
  url       String
  mimeType  String
  size      BigInt
  key       String
  createdAt DateTime @default(now())

  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([tenantId, key])
  @@index([tenantId, dealId])
}

model FollowUp {
  id          String    @id @default(cuid())
  tenantId    String
  dealId      String
  date        DateTime
  note        String?
  result      String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdById String?
  createdAt   DateTime  @default(now())

  deal      Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  createdBy User? @relation("FollowUpCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, dealId])
  @@index([tenantId, completed, date])
}

model Note {
  id          String   @id @default(cuid())
  tenantId    String
  dealId      String?
  clientId    String?
  text        String
  createdById String?
  createdAt   DateTime @default(now())

  deal      Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  client    Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("NoteCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, dealId])
  @@index([tenantId, clientId])
}

model Activity {
  id        String   @id @default(cuid())
  tenantId  String
  entity    String
  entityId  String
  type      String
  payload   Json
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation("ActivityUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
}

model SavedView {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  entity    String
  name      String
  config    Json
  createdAt DateTime @default(now())

  user User? @relation("SavedViewUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, entity])
}

model Counter {
  tenantId String
  key      String
  value    Int    @default(0)

  @@id([tenantId, key])
}

model CustomFieldDefinition {
  id        String   @id @default(cuid())
  tenantId  String
  entity    String
  key       String
  label     String
  type      String
  options   Json?
  required  Boolean  @default(false)
  order     Int      @default(0)
  metadata  Json?
  createdAt DateTime @default(now())

  @@unique([tenantId, entity, key])
  @@index([tenantId, entity])
}

model RateLimitEntry {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime

  @@map("rate_limit_entries")
}
