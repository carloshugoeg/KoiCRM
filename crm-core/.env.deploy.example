# Copy to .env.deploy.local (gitignored) and fill values before: pnpm ops:bootstrap
# Docs: LAUNCH_RUNBOOK.md → "Automated path"

# ─── Vercel ───────────────────────────────────────────────────────────────────
# https://vercel.com/account/tokens
VERCEL_TOKEN=
# Team ID (team_…) from Vercel → Settings. Optional if only one team.
VERCEL_ORG_ID=
# Project ID (prj_…) — optional; bootstrap links/creates VERCEL_PROJECT_NAME if empty
VERCEL_PROJECT_ID=
VERCEL_PROJECT_NAME=koi-crm

# ─── Supabase (Postgres only) ─────────────────────────────────────────────────
# SUPABASE_ACCESS_TOKEN = Management API token (Account → Access Tokens).
#   NOT a database URL. Optional if `supabase login` or Cursor Supabase MCP works.
#   Unrelated to Direct / Transaction / Session pooler in the dashboard.
#
# SUPABASE_DB_PASSWORD = postgres user password for the project (Settings → Database).
#
# Bootstrap builds DATABASE_URL / DATABASE_ADMIN_URL for you:
#   DATABASE_URL         → Shared pooler + postgres.<ref> (IPv4/Vercel); app uses SET ROLE app_user
# Optional — pooler hostname from Dashboard (aws-0 vs aws-1 varies)
# SUPABASE_POOLER_HOST=aws-1-us-east-1.pooler.supabase.com
# Optional — paste full Transaction pooler URI from Dashboard (skips auto-detect)
# SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@HOST:6543/postgres?pgbouncer=true
#   DATABASE_ADMIN_URL   → Direct :5432 on db.<ref>.supabase.co + admin_user (migrations)
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# https://supabase.com/dashboard/org/_/general — Organization ID
SUPABASE_ORG_ID=
# Strong password for the new project's postgres role (min 12 chars)
SUPABASE_DB_PASSWORD=
# Region aligned with vercel.json (iad1 → us-east-1)
SUPABASE_REGION=us-east-1
# Optional — set after first run to resume without creating a new project
SUPABASE_PROJECT_REF=
SUPABASE_PROJECT_NAME=koi-crm-prod

# Passwords for RLS roles (generated on first run if empty)
APP_USER_PASSWORD=
ADMIN_USER_PASSWORD=

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generated on first run if empty
AUTH_SECRET=
# Production app URL (no trailing slash). Set if Vercel alias differs from project name
# (e.g. project koi-crm → domain https://koicrm.vercel.app). Bootstrap auto-detects from deploy if empty.
AUTH_URL=

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_BUCKET=koicrm-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_PUBLIC_URL=

# ─── First tenant (non-interactive seed) ──────────────────────────────────────
SEED_TENANT_NAME="AquaXela"
SEED_TENANT_SLUG=aquaxela
SEED_ADMIN_NAME="Koi CRM Admin"
SEED_ADMIN_EMAIL=koicrm@aquaxela.com
SEED_ADMIN_PASSWORD="Aquaxela.CRM.Seguridad"

# ─── Optional Google OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
