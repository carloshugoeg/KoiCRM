# ─── Database ────────────────────────────────────────────────────────────────
# Use the POOLED connection string for the app (PgBouncer/Supavisor).
# Neon:     add ?pgbouncer=true&connect_timeout=10 to the pooled URL
# Supabase: use port 6543 (Transaction Pooler), NOT 5432
DATABASE_URL="postgresql://app_user:CHANGE_ME@HOST:PORT/koicrm?pgbouncer=true&connect_timeout=10"

# Direct connection (db.<ref>.supabase.co:5432) — NOT the pooler host. Migrations/seeds only.
# Never expose this to the app at runtime.
DATABASE_ADMIN_URL="postgresql://admin_user:CHANGE_ME@db.PROJECT_REF.supabase.co:5432/postgres"

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"

# Full canonical URL of the app (no trailing slash).
# Must match the Vercel deployment URL or custom domain.
AUTH_URL="https://app.yourdomain.com"

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
# Leave blank to disable Google sign-in.
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Create at: https://resend.com → API Keys
# Verify your sending domain in Resend before launch.
RESEND_API_KEY="re_CHANGE_ME"

# ─── File Storage (Cloudflare R2 or S3-compatible) ───────────────────────────
# Create bucket at: https://dash.cloudflare.com → R2 Object Storage
# S3_PUBLIC_URL is the public bucket URL (r2.dev subdomain or custom domain).
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_BUCKET="koicrm-uploads"
S3_ACCESS_KEY_ID="CHANGE_ME"
S3_SECRET_ACCESS_KEY="CHANGE_ME"
S3_REGION="auto"
S3_PUBLIC_URL="https://pub-XXXXXXXX.r2.dev"

# ─── Sentry (optional — omit for deploy without error tracking) ─────────────
# If SENTRY_AUTH_TOKEN is unset, next.config.mjs skips Sentry webpack plugin.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
LOG_LEVEL="error"
