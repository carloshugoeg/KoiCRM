{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:3000",
          "https://koicrm.vercel.app",
          "https://koicrm.aquaxela.com",
          "https://*.vercel.app"
        ],
        "methods": ["GET", "PUT", "HEAD"],
        "headers": ["Content-Type", "Content-Length"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
